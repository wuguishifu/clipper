{
  "name": "vulcan",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/vulcan",
  "projectType": "application",
  "tags": ["scope:client"],
  "// targets": "to see all targets run: nx show project vulcan --web",
  "targets": {
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": true,
        "commands": ["rm -rf ./.next", "rm -rf ./.env.local"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^typecheck"],
      "cache": true,
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/tsconfig.base.json",
        {
          "dependentTasksOutputFiles": "**/*.{d.ts,tsbuildinfo}",
          "transitive": true
        },
        { "fileset": "{projectRoot}/**/*.d.ts", "dependencies": true },
        { "externalDependencies": ["next", "typescript"] }
      ],
      "outputs": [
        "{projectRoot}/.next/types/**/*.ts",
        "{projectRoot}/dist/tsconfig.tsbuildinfo"
      ],
      "syncGenerators": ["@nx/js:typescript-sync"],
      "options": {
        "cwd": "apps/vulcan",
        "command": "next typegen && tsc --project tsconfig.json --noEmit"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo tauri dev",
        "cwd": "apps/vulcan"
      }
    },
    "dev": {
      "options": {
        "port": 4200
      }
    },
    "start": {
      "options": {
        "port": 4200
      }
    },
    "tauri": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo tauri",
        "cwd": "apps/vulcan"
      }
    }
  }
}
